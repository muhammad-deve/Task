                    }
                },
                "meta": {
                    "$ref": "#/definitions/model.PaginationMeta"
                }
            }
        },
        "model.LogActivityRequest": {
            "type": "object",
            "properties": {
                "action": {
                    "$ref": "#/definitions/model.ActivityAction"
                },
                "notes": {
                    "type": "string"
                }
            }
        },
