                }
            }
        },
        "model.DriverResponse": {
            "type": "object",
            "properties": {
                "car_model": {
                    "type": "string"
                },
                "car_plate": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "full_name": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "license_number": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/definitions/model.DriverStatus"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "model.DriverStatus": {
            "type": "string",
            "enum": [
                "active",
                "inactive",
                "blocked"
