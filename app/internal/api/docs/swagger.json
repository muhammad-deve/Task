                "driver_id": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "notes": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                }
            }
        },
        "model.CreateDriverRequest": {
            "type": "object",
            "properties": {
                "car_model": {
                    "type": "string"
                },
                "car_plate": {
                    "type": "string"
                },
                "full_name": {
                    "type": "string"
                },
                "license_number": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/definitions/model.DriverStatus"
                }
            }
        },
        "model.DriverErrorResponse": {
