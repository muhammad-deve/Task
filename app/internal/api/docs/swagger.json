                "active_count": {
                    "type": "integer"
                }
            }
        },
        "model.ActivityAction": {
            "type": "string",
            "enum": [
                "went_online",
                "went_offline"
            ],
            "x-enum-varnames": [
                "ActionWentOnline",
                "ActionWentOffline"
            ]
        },
        "model.ActivityLogResponse": {
            "type": "object",
            "properties": {
                "action": {
                    "$ref": "#/definitions/model.ActivityAction"
