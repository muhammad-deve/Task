                "message": {
                    "type": "string"
                }
            }
        },
        "model.ErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "error message"
                }
            }
        },
        "model.ListDriversResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "array",
